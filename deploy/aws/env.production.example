# Copy to /etc/securechat.env on the EC2 host (chmod 600). Fill secrets via Secrets Manager
# bootstrap or SSM; do not commit real values.
#
# Load balancer → EC2 on port 8080 (matches SecureChatBackend/Dockerfile).

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
ForwardedHeaders__Enabled=true

# Region for SecureChat Network / Path (EC2 does not always set AWS_REGION for user processes).
AWS_REGION=us-east-1

# Optional: human-readable deploy label. If unset, EC2_INSTANCE_ID or ECS task ARN is used when available.
SECURECHAT_DEPLOYMENT_LABEL=securechat-prod-v1

# Optional: set from IMDSv2 in user-data (see user-data-bootstrap.sh). Used if SECURECHAT_DEPLOYMENT_LABEL is empty.
# EC2_INSTANCE_ID=i-0123456789abcdef0

ConnectionStrings__DefaultConnection=Host=YOUR_RDS_ENDPOINT;Port=5432;Database=securechat_db;Username=APPUSER;Password=YOUR_PASSWORD;SSL Mode=Require
JwtSettings__Secret=USE_A_LONG_RANDOM_SECRET_AT_LEAST_32_BYTES
Database__UseInMemory=false

# Optional explicit CORS origins (in addition to *.vercel.app / localhost built into the API).
# Cors__AllowedOrigins__0=https://your-app.vercel.app
