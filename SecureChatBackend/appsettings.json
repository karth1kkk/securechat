{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=8081;Database=securechat;Username=securechat;Password=secure-password"
  },
  "JwtSettings": {
    "Issuer": "SecureChatBackend",
    "Audience": "SecureChatClients",
    "Secret": "ReplaceWithA32ByteSecretValue!",
    "TokenLifetimeMinutes": 10080
  },
  "RateLimiting": {
    "PermitLimit": 30,
    "WindowSeconds": 60
  },
  "Database": {
    "UseInMemory": false
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:8081",
      "http://localhost:8082"
    ]
  }
}
