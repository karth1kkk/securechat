GRAPHQL_URL=http://localhost:5002/graphql
API_URL=http://localhost:5002

# Used by app.config.js + config.ts (GraphQL, SignalR, Call hub, WebRTC). Must match the backend you use.
# For hosted / production builds, set these to your deployed API (HTTPS). Localhost only works on a simulator on the same machine.
EXPO_PUBLIC_API_URL=https://securechat-backend-2250e8faaf8d.herokuapp.com/
EXPO_PUBLIC_GRAPHQL_URL=https://securechat-backend-2250e8faaf8d.herokuapp.com/graphql

# Production example (uncomment and rebuild the app — env is baked in at build time):
# EXPO_PUBLIC_API_URL=https://your-api.example.com
# EXPO_PUBLIC_GRAPHQL_URL=https://your-api.example.com/graphql

# Optional WebRTC ICE (use TURN on restrictive networks; set all three TURN vars)
# EXPO_PUBLIC_ICE_STUN_URLS=stun:stun.l.google.com:19302
# EXPO_PUBLIC_ICE_TURN_URLS=turn:turn.example.com:3478
# EXPO_PUBLIC_ICE_TURN_USERNAME=
# EXPO_PUBLIC_ICE_TURN_CREDENTIAL=
