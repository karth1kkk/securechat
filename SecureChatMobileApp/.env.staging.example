# Copy to .env for local "expo export -p web" tests against staging, or set the same
# keys in Vercel → Project → Settings → Environment Variables (Preview / Production).

EXPO_PUBLIC_API_URL=https://your-staging-api.example.com
EXPO_PUBLIC_GRAPHQL_URL=https://your-staging-api.example.com/graphql

# Optional: GIF search in chat (https://developers.giphy.com/)
EXPO_PUBLIC_GIPHY_API_KEY=
